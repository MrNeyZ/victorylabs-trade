{
  "name": "victorylabs-trade",
  "version": "0.1.0",
  "private": true,
  "description": "Smart Money analytics platform for Jupiter Prediction",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "db:migrate": "tsx src/backend/db/migrate.ts",
    "ingest:trades:once": "tsx src/backend/jobs/ingestTradesOnce.ts",
    "ingest:trades:poll": "tsx src/backend/jobs/pollTrades.ts",
    "ingest:history:recent": "tsx src/backend/jobs/ingestRecentWalletHistory.ts",
    "ingest:rankings": "tsx src/backend/jobs/ingestRankings.ts",
    "ingest:positions:recent": "tsx src/backend/jobs/ingestRecentWalletPositions.ts",
    "backend:dev": "tsx watch src/backend/api/server.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
