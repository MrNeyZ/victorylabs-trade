{
  "name": "victorylabs-trade",
  "version": "0.1.0",
  "private": true,
  "description": "Smart Money analytics platform for Jupiter Prediction",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "db:migrate": "tsx src/backend/db/migrate.ts",
    "ingest:trades:once": "tsx src/backend/jobs/ingestTradesOnce.ts",
    "ingest:trades:poll": "tsx src/backend/jobs/pollTrades.ts",
    "ingest:history:recent": "tsx src/backend/jobs/ingestRecentWalletHistory.ts",
    "ingest:rankings": "tsx src/backend/jobs/ingestRankings.ts",
    "ingest:positions:recent": "tsx src/backend/jobs/ingestRecentWalletPositions.ts",
    "analytics:wallet": "tsx src/backend/jobs/analyticsWallet.ts",
    "analytics:leaderboard": "tsx src/backend/jobs/analyticsLeaderboard.ts",
    "analytics:scores": "tsx src/backend/jobs/computeWalletScores.ts",
    "analytics:signals": "tsx src/backend/jobs/analyticsSignals.ts",
    "analytics:signals:persist": "tsx src/backend/jobs/persistSmartMoneySignals.ts",
    "demo:prepare": "npm run db:migrate && npm run ingest:trades:once && npm run ingest:rankings && npm run ingest:positions:recent && npm run ingest:history:recent && npm run analytics:scores && npm run analytics:signals:persist -- --lookbackMinutes=1440 --minSmartScore=1 --whaleUsd=15 --consensusWallets=2",
    "backend:dev": "tsx watch src/backend/api/server.ts",
    "backend:start": "tsx src/backend/api/server.ts",
    "frontend:dev": "next dev src/frontend",
    "frontend:build": "next build src/frontend",
    "frontend:start": "next start src/frontend -p 4200",
    "dev:backend": "npm run backend:dev",
    "dev:frontend": "npm run frontend:dev",
    "dev:ingest:trades": "npm run ingest:trades:poll",
    "dev:all": "npm run db:migrate && npm run ingest:trades:poll && concurrently -n backend,frontend -c blue,magenta \"npm:backend:dev\" \"npm:frontend:dev\""
  },
  "dependencies": {
    "express": "^5.2.1",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "overrides": {
    "postcss": "^8.5.16"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
